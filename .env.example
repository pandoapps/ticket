APP_PORT=8080
VITE_PORT=5173

# In production, the nginx container publishes fixed ports 80 + 443
# (APP_PORT is used for dev only). TLS termination happens via Cloudflare
# Origin Certificate mounted from /etc/ssl/cloudflare on the host.

# Host user/group IDs — used at image build to keep container files owned
# by the same UID/GID as the host, avoiding bind-mount permission issues.
# Set these to `id -u` / `id -g` on Linux hosts. Safe default for macOS.
UID=1000
GID=1000

# Use "db" for the bundled MySQL container (dev).
# In production, point to your external database host (e.g. db.internal.example.com).
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ticketeira
DB_USERNAME=ticketeira
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_strong_root_password
