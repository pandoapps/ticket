APP_NAME=Ticketeira
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
# In production: APP_URL=https://cursos.pandoapps.com.br and FRONTEND_URL matches

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ticketeira
DB_USERNAME=ticketeira
DB_PASSWORD=change_me_strong_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# In production, set SESSION_SECURE_COOKIE=true and SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Sanctum SPA auth — list domains allowed to use stateful session cookies.
# In production: SANCTUM_STATEFUL_DOMAINS=cursos.pandoapps.com.br
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@ticketeira.local"
MAIL_FROM_NAME="${APP_NAME}"

ABACATE_PAY_SANDBOX_URL=https://api.abacatepay.com/v2
ABACATE_PAY_PRODUCTION_URL=https://api.abacatepay.com/v2

SANCTUM_EXPIRATION=10080
